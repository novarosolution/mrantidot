# Copy these keys into Render → Environment (do not commit real secrets)

NODE_ENV=production
MONGO_URI=mongodb+srv://USER:PASSWORD@cluster.mongodb.net/mrantidot?retryWrites=true&w=majority
JWT_SECRET=replace_with_long_random_string
CLIENT_URL=*

ADMIN_PHONE=9000000001
ADMIN_PASSWORD=change_me
ADMIN_NAME=Admin
ADMIN_EMAIL=admin@mrantidot.com
ADMIN_CITY=Mumbai
ENSURE_ADMIN_ON_STARTUP=true
