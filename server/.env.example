# Local dev (no "." in database name — MongoDB rejects names like mrantidot-2.0)
MONGO_URI=mongodb://127.0.0.1:27017/mrantidot-v2

# Production (Render / Atlas): use mongodb+srv://.../mrantidot-v2
JWT_SECRET=supersecret_change_me
PORT=4000
NODE_ENV=development
CLIENT_URL=*

# Admin account — synced to MongoDB on server start and when you run npm run seed
ADMIN_PHONE=9000000001
ADMIN_PASSWORD=admin123
ADMIN_NAME=Ravi Admin
ADMIN_EMAIL=admin@mrantidot.com
ADMIN_CITY=Mumbai

# Set to false to skip auto-creating admin on API startup
ENSURE_ADMIN_ON_STARTUP=true
